{
  "name": "@submittedit/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "authority:keygen": "node scripts/generate-authority-key.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "prebuild": "pnpm --filter @submittedit/receipt-core build",
    "predev": "pnpm --filter @submittedit/receipt-core build",
    "pretest": "pnpm --filter @submittedit/receipt-core build",
    "pretypecheck": "pnpm --filter @submittedit/receipt-core build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "typegen": "next typegen"
  },
  "dependencies": {
    "@submittedit/receipt-core": "workspace:*",
    "@submittedit/ui": "workspace:*",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "vitest": "4.1.10"
  }
}
