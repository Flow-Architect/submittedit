{
  "name": "@submittedit/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "authority:keygen": "node scripts/generate-authority-key.mjs",
    "audit:relay-client": "node scripts/audit-relay-client.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "prebuild": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/contract-client build",
    "predev": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/contract-client build",
    "pretest": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/contract-client build",
    "pretypecheck": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/contract-client build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts && pnpm test:relay-smoke-safety",
    "test:relay-local-chain": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/contract-client build && node scripts/test-relay-local-chain.mjs",
    "test:relay-monad-smoke:wallet": "node scripts/refuse-relay-monad-smoke-rerun.mjs",
    "postflight:relay-monad-smoke": "node scripts/relay-monad-smoke-postflight.mjs --stdin",
    "reconcile:relay-monad-smoke": "pnpm --filter @submittedit/contract-client build && node scripts/reconcile-relay-monad-smoke.mjs --rpc-url https://testnet-rpc.monad.xyz --chain-id 10143 --contract 0x63914900a2D3571F92506821a76c4036C3e25883 --relayer 0x63314854E3e5366aF1155B72c1d730d9400397eF --transaction 0x71315582a64d576454137732ec8aa139c9688d915f2fab44b97b977c10e38a16 --block 46136733 --receipt-id 0x466c721416db5ba7e9127f3b606a397c417f15d6018f23e65484610536556d5b --event-hash 0x427113beeff23f825ecd342047e822a15265b1e9dcf8a5625f1feb4eecf801d0 --extension-key-hash 0x1c4167ff3c69b66279e58773bdc30d8343ba41ff6cbc32ee4c8485d9280dd636 --minimum-balance-wei 4950000000000000000",
    "test:relay-smoke-safety": "pnpm --filter @submittedit/contract-client build && node --test scripts/relay-monad-smoke-guard.test.mjs scripts/relay-monad-smoke-postflight.test.mjs scripts/relay-monad-smoke-reconcile.test.mjs",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "typegen": "next typegen"
  },
  "dependencies": {
    "@submittedit/contract-client": "workspace:*",
    "@submittedit/receipt-core": "workspace:*",
    "@submittedit/ui": "workspace:*",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "vitest": "4.1.10"
  }
}
