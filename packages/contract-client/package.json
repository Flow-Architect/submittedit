{
  "name": "@submittedit/contract-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "abi:check": "node ../../contracts/scripts/export-abi.mjs --check",
    "build": "tsc --project tsconfig.build.json",
    "deployment:check": "node scripts/sync-deployment.mjs --check",
    "test": "vitest run --config vitest.config.ts",
    "test:exports": "node test/export-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "2.55.2"
  },
  "devDependencies": {
    "vitest": "4.1.10"
  }
}
