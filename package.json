{
  "name": "submittedit",
  "version": "0.0.0",
  "private": true,
  "description": "SubmittedIt engineering workspace",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @submittedit/web --filter @submittedit/extension dev",
    "build": "pnpm --recursive --if-present build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "icons:generate": "node scripts/generate-icons.mjs",
    "icons:check": "node scripts/generate-icons.mjs --check",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "vitest run && pnpm --filter @submittedit/receipt-core test",
    "test:browser-parity": "pnpm --filter @submittedit/receipt-core build && pnpm --filter @submittedit/receipt-core test:exports && playwright test --config playwright.receipt-core.config.ts",
    "test:e2e": "playwright test && pnpm test:browser-parity && pnpm --filter @submittedit/web typegen",
    "secrets:check": "node scripts/check-secrets.mjs",
    "check": "pnpm format:check && pnpm icons:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:browser-parity && pnpm secrets:check"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
